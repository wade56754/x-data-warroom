# ── Required ─────────────────────────────────────────────────────────────────

# Supabase PostgreSQL connection URL
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.YOURREF:YOURPASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# TikHub API key (for tweet data collection)
# Get yours at https://tikhub.io/
TIKHUB_API_KEY=your_tikhub_api_key_here

# ── Identity ─────────────────────────────────────────────────────────────────

# Your X (Twitter) screen name (without @)
X_SCREEN_NAME=mytwitter

# ── Paths (optional — defaults shown) ────────────────────────────────────────

# Directory where data files and this .env live (default: ~/.x-data/)
# X_DATA_DIR=~/.x-data

# Absolute path to the growth tracker JSON file
# TWEET_GROWTH_DATA=~/.x-data/data.json

# ── Telegram alerts (optional) ────────────────────────────────────────────────

# Bot token from @BotFather
# TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat / channel ID to send alerts to
# TELEGRAM_HOME_CHANNEL=123456789

# ── Dashboard ────────────────────────────────────────────────────────────────

# Port for the local dashboard (default: 8787)
# DASHBOARD_PORT=8787
